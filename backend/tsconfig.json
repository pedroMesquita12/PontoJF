{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",

    "incremental": true,
    "skipLibCheck": true
  }
}